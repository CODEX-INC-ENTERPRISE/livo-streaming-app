# Server Configuration
NODE_ENV=development
PORT=3000

# Database Configuration
MONGODB_URI=mongodb://localhost:27017/social-streaming
MONGODB_MIN_POOL_SIZE=10
MONGODB_MAX_POOL_SIZE=100

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Firebase Configuration (Optional - for social auth)
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project-id.iam.gserviceaccount.com

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRATION=30d

# Email Configuration (for OTP)
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USER=your-email@example.com
EMAIL_PASSWORD=your-email-password
EMAIL_FROM=noreply@example.com

# SMS Configuration (for OTP)
SMS_GATEWAY_URL=https://sms-gateway.example.com/send
SMS_GATEWAY_API_KEY=your-sms-api-key

# OTP Configuration
OTP_EXPIRATION_SECONDS=300
OTP_RATE_LIMIT_WINDOW=900
OTP_RATE_LIMIT_MAX=5

# Security Configuration
BCRYPT_ROUNDS=12
SESSION_TIMEOUT_DAYS=30

# Agora Configuration (for streaming)
AGORA_APP_ID=your-agora-app-id
AGORA_APP_CERTIFICATE=your-agora-certificate

# Business Rules
COMMISSION_RATE=0.15
DIAMOND_TO_CREDIT_RATE=0.01
MIN_WITHDRAWAL_DIAMONDS=1000

# CORS Configuration
CORS_ORIGIN=*
