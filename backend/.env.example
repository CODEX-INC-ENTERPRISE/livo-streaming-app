# Server Configuration
NODE_ENV=development
PORT=3000

# Database Configuration
MONGODB_URI=mongodb://localhost:27017/social-streaming
MONGODB_MIN_POOL_SIZE=10
MONGODB_MAX_POOL_SIZE=100

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Firebase Configuration (Optional - for social auth)
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project-id.iam.gserviceaccount.com

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRATION=30d

# Email OTP (Resend - https://resend.com - free tier: 3000 emails/month)
# Sign up at resend.com, create an API key, verify your domain
RESEND_API_KEY=re_your_api_key_here
RESEND_FROM_EMAIL=noreply@yourdomain.com

# SMS OTP (Twilio - https://twilio.com - free trial available)
# Sign up at twilio.com, get Account SID, Auth Token, and a phone number
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+1234567890

# OTP Configuration
OTP_EXPIRATION_SECONDS=300
OTP_RATE_LIMIT_WINDOW=900
OTP_RATE_LIMIT_MAX=5

# Security Configuration
BCRYPT_ROUNDS=12
SESSION_TIMEOUT_DAYS=30

# Agora Configuration (for streaming)
AGORA_APP_ID=your-agora-app-id
AGORA_APP_CERTIFICATE=your-agora-certificate

# Business Rules
COMMISSION_RATE=0.15
DIAMOND_TO_CREDIT_RATE=0.01
MIN_WITHDRAWAL_DIAMONDS=1000

# CORS Configuration
CORS_ORIGIN=*

# Stripe Configuration (for payment processing)
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key

# PayPal Configuration (for payment processing)
PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_CLIENT_SECRET=your-paypal-client-secret
PAYPAL_WEBHOOK_SECRET=your-paypal-webhook-secret

# Mada Configuration (for Saudi payment processing)
MADA_API_KEY=your-mada-api-key
MADA_MERCHANT_ID=your-mada-merchant-id
MADA_TERMINAL_ID=your-mada-terminal-id
MADA_WEBHOOK_SECRET=your-mada-webhook-secret
MADA_ENVIRONMENT=sandbox

# stc pay Configuration (for Saudi payment processing)
STCPAY_CLIENT_ID=your-stcpay-client-id
STCPAY_CLIENT_SECRET=your-stcpay-client-secret
STCPAY_MERCHANT_ID=your-stcpay-merchant-id
STCPAY_WEBHOOK_SECRET=your-stcpay-webhook-secret
STCPAY_ENVIRONMENT=sandbox

# Firebase Cloud Messaging (FCM) Configuration
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"your-project-id","private_key_id":"your-private-key-id","private_key":"-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY\n-----END PRIVATE KEY-----\n","client_email":"firebase-adminsdk@your-project-id.iam.gserviceaccount.com","client_id":"1234567890","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_x509_cert_url":"https://www.googleapis.com/robot/v1/metadata/x509/firebase-adminsdk%40your-project-id.iam.gserviceaccount.com"}